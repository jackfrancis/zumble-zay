# ---- Server ----
# Address the HTTP server listens on.
ADDR=:8080

# Public base URL used to build OAuth redirect URLs (no trailing slash).
# In production this MUST be https.
BASE_URL=http://localhost:8080

# Comma-separated list of allowed CORS origins. Empty disables CORS.
ALLOWED_ORIGINS=http://localhost:8080

# ---- Sessions ----
# 32+ byte random secret used to authenticate session cookies.
# Generate with: openssl rand -base64 48
SESSION_SECRET=

# Set to "true" only when served over HTTPS so the Secure cookie flag is set.
COOKIE_SECURE=false

# ---- OAuth providers ----
# Leave a provider's client ID/secret empty to disable that provider.

# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft (Azure AD): https://portal.azure.com -> App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# "common", "organizations", "consumers", or a specific tenant ID.
MICROSOFT_TENANT=common
